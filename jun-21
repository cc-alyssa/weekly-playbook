opacity:0;color:#fff;font-size:13px;font-weight:700;line-height:1;transition:opacity 0.18s ease;\">✓<\u002Fspan><\u002Fspan>\n            <span class=\"pb-label\" data-color=\"#242424\" style=\"font-size:16px;line-height:1.45;color:#242424;flex:1;transition:color 0.18s ease;\">Engage with your followers 10 min/day (story replies, comments, DMs)<\u002Fspan>\n          <\u002Fdiv>\n\n          <div class=\"pb-row\" data-pb-key=\"ew-eng-2\" onclick=\"{{ toggle }}\" style=\"display:flex;gap:14px;align-items:flex-start;padding:13px 0;cursor:pointer;border-bottom:1px solid #F3F3F0;transition:transform 0.12s ease;\">\n            <span class=\"pb-box\" style=\"flex:none;width:23px;height:23px;border-radius:7px;border:1.5px solid #242424;background:#fff;display:flex;align-items:center;justify-content:center;margin-top:1px;transition:background 0.18s ease,border-color 0.18s ease;\"><span class=\"pb-check\" style=\"opacity:0;color:#fff;font-size:13px;font-weight:700;line-height:1;transition:opacity 0.18s ease;\">✓<\u002Fspan><\u002Fspan>\n            <span class=\"pb-label\" data-color=\"#242424\" style=\"font-size:16px;line-height:1.45;color:#242424;flex:1;transition:color 0.18s ease;\">Engage with non-followers 10 min/day (local accounts, new followers, comments)<\u002Fspan>\n          <\u002Fdiv>\n\n          <div class=\"pb-row\" data-pb-key=\"ew-reel\" onclick=\"{{ toggle }}\" style=\"display:flex;gap:14px;align-items:flex-start;padding:13px 0;cursor:pointer;border-bottom:1px solid #F3F3F0;transition:transform 0.12s ease;\">\n            <span class=\"pb-box\" style=\"flex:none;width:23px;height:23px;border-radius:7px;border:1.5px solid #242424;background:#fff;display:flex;align-items:center;justify-content:center;margin-top:1px;transition:background 0.18s ease,border-color 0.18s ease;\"><span class=\"pb-check\" style=\"opacity:0;color:#fff;font-size:13px;font-weight:700;line-height:1;transition:opacity 0.18s ease;\">✓<\u002Fspan><\u002Fspan>\n            <span class=\"pb-label\" data-color=\"#242424\" style=\"font-size:16px;line-height:1.45;color:#242424;flex:1;transition:color 0.18s ease;\">Try a talking head reel with Content Studio<\u002Fspan>\n          <\u002Fdiv>\n\n          <div class=\"pb-row\" data-pb-key=\"ew-learn\" onclick=\"{{ toggle }}\" style=\"display:flex;gap:14px;align-items:flex-start;padding:13px 0 4px;cursor:pointer;transition:transform 0.12s ease;\">\n            <span class=\"pb-box\" style=\"flex:none;width:23px;height:23px;border-radius:7px;border:1.5px solid #242424;background:#fff;display:flex;align-items:center;justify-content:center;margin-top:1px;transition:background 0.18s ease,border-color 0.18s ease;\"><span class=\"pb-check\" style=\"opacity:0;color:#fff;font-size:13px;font-weight:700;line-height:1;transition:opacity 0.18s ease;\">✓<\u002Fspan><\u002Fspan>\n            <span class=\"pb-label\" data-color=\"#242424\" style=\"font-size:16px;line-height:1.45;color:#242424;flex:1;transition:color 0.18s ease;\">Carve out 1 hr of marketing learning time — a Coffee &amp; Contracts course, new feature, or Claude<\u002Fspan>\n          <\u002Fdiv>\n        <\u002Fsection>\n\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <!-- ============ FOOTER ============ -->\n    <footer style=\"margin-top:18px;background:#FFFFFF;border:1px solid #EFEFE8;border-radius:20px;padding:18px 26px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;\">\n      <p style=\"margin:0;font-size:12px;line-height:1.45;color:#9C9A8B;max-width:62%;min-width:200px;\">Your checkmarks save to this device — bookmark the link and pick up right where you left off.<\u002Fp>\n      <button onclick=\"{{ reset }}\" style=\"flex:none;font-family:'PP Neue Montreal',sans-serif;font-size:12.5px;letter-spacing:0.04em;color:#454545;background:transparent;border:1.5px solid #DEDDCE;border-radius:99px;padding:9px 18px;cursor:pointer;transition:border-color 0.18s ease,color 0.18s ease;\" style-hover=\"border-color:#242424;color:#242424;\">Reset checklist<\u002Fbutton>\n    <\u002Ffooter>\n\n  <\u002Fdiv>\n<\u002Fdiv>\n<\u002Fx-dc>\n<script type=\"text/x-dc\" data-dc-script=\"\" data-props=\"{&quot;$preview&quot;:{&quot;width&quot;:1080,&quot;height&quot;:900}}\">\nclass Component extends DCLogic {\n  KEY = 'cc-weekly-playbook-jun22-v1';\n\n  componentDidMount() {\n    try {\n      this.store = JSON.parse(localStorage.getItem(this.KEY) || '{}');\n    } catch (e) {\n      this.store = {};\n    }\n    document.querySelectorAll('#pb-card [data-pb-key]').forEach((row) => {\n      this.applyRow(row, !!this.store[row.dataset.pbKey]);\n    });\n    this.updateProgress();\n  }\n\n  applyRow(row, done) {\n    const box = row.querySelector('.pb-box');\n    const check = row.querySelector('.pb-check');\n    const label = row.querySelector('.pb-label');\n    if (!box || !check || !label) return;\n    if (done) {\n      box.style.background = '#999E66';\n      box.style.borderColor = '#999E66';\n      check.style.opacity = '1';\n      label.style.color = '#B9B9B9';\n      label.style.textDecoration = 'line-through';\n    } else {\n      box.style.background = '#FFFFFF';\n      box.style.borderColor = label.dataset.color === '#454545' ? '#737373' : '#242424';\n      check.style.opacity = '0';\n      label.style.color = label.dataset.color || '#242424';\n      label.style.textDecoration = 'none';\n    }\n  }\n\n  updateProgress() {\n    const rows = document.querySelectorAll('#pb-card [data-pb-key]');\n    const total = rows.length;\n    let done = 0;\n    rows.forEach((r) => { if (this.store[r.dataset.pbKey]) done++; });\n    const fill = document.getElementById('pb-fill');\n    const text = document.getElementById('pb-progress-text');\n    if (fill) fill.style.width = total ? (done / total * 100) + '%' : '0%';\n    if (text) text.textContent = done + ' of ' + total + ' done';\n  }\n\n  toggle = (e) => {\n    const row = e.currentTarget;\n    const key = row.dataset.pbKey;\n    const done = !this.store[key];\n    if (done) this.store[key] = true; else delete this.store[key];\n    try { localStorage.setItem(this.KEY, JSON.stringify(this.store)); } catch (err) {}\n    this.applyRow(row, done);\n    this.updateProgress();\n  };\n\n  reset = () => {\n    this.store = {};\n    try { localStorage.removeItem(this.KEY); } catch (err) {}\n    document.querySelectorAll('#pb-card [data-pb-key]').forEach((row) => this.applyRow(row, false));\n    this.updateProgress();\n  };\n\n  renderVals() {\n    return { toggle: this.toggle, reset: this.reset };\n  }\n}\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
